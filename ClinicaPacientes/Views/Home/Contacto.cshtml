@{
    ViewData["Title"] = "Contacto";
}

<!-- Bootstrap Icons CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    /* ═══════════════════════════════════════════
           VARIABLES (mismas que Inicio / Pacientes)
        ═══════════════════════════════════════════ */
    :root {
        --cp-primary: #0a5c8c;
        --cp-primary-dark: #07436a;
        --cp-primary-light: #1a7ab5;
        --cp-accent: #00a99d;
        --cp-accent-light: #e6f7f6;
        --cp-red: #e63946;
        --cp-text: #1e2d3d;
        --cp-text-muted: #5a6a7a;
        --cp-bg: #f4f8fb;
        --cp-white: #ffffff;
        --cp-border: #dce8f0;
        --cp-shadow: 0 4px 20px rgba(10,92,140,0.10);
        --cp-shadow-lg: 0 10px 40px rgba(10,92,140,0.18);
    }

    /* ═══════════════════════════════════════════
           HERO
        ═══════════════════════════════════════════ */
    .contact-hero {
        background: linear-gradient(120deg, var(--cp-primary-dark) 0%, var(--cp-primary) 50%, var(--cp-primary-light) 100%);
        padding: 64px 24px 54px;
        text-align: center;
        color: white;
        position: relative;
        overflow: hidden;
        margin-bottom: 0;
    }

        .contact-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
        }

    .contact-hero-blob {
        position: absolute;
        width: 380px;
        height: 380px;
        border-radius: 50%;
        background: rgba(0,169,157,0.15);
        bottom: -140px;
        right: -80px;
        pointer-events: none;
    }

    .contact-hero-inner {
        position: relative;
        z-index: 2;
        max-width: 700px;
        margin: 0 auto;
    }

    .contact-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.25);
        padding: 6px 18px;
        border-radius: 20px;
        font-size: 0.82rem;
        font-weight: 500;
        margin-bottom: 20px;
        color: rgba(255,255,255,0.95);
    }

    .contact-hero h1 {
        font-size: 2.6rem;
        font-weight: 800;
        margin-bottom: 14px;
        text-shadow: 0 2px 10px rgba(0,0,0,0.15);
    }

        .contact-hero h1 span {
            color: #7ee8e2;
        }

    .contact-hero p {
        font-size: 1rem;
        opacity: 0.88;
        line-height: 1.7;
        max-width: 560px;
        margin: 0 auto;
    }

    /* ═══════════════════════════════════════════
           SECCIÓN PRINCIPAL
        ═══════════════════════════════════════════ */
    .contact-section {
        background: var(--cp-bg);
        padding: 54px 0 70px;
    }

    .contact-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 24px;
    }

    /* ═══════════════════════════════════════════
           CABECERA DE SECCIÓN
        ═══════════════════════════════════════════ */
    .contact-section-badge {
        display: inline-block;
        background: var(--cp-accent-light);
        color: var(--cp-accent);
        padding: 5px 16px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .contact-section-title {
        font-size: 1.7rem;
        font-weight: 800;
        color: var(--cp-text);
        margin: 0 0 6px;
    }

    .contact-section-sub {
        font-size: 0.9rem;
        color: var(--cp-text-muted);
        margin: 0 0 32px;
    }

    .contact-divider {
        width: 60px;
        height: 4px;
        background: linear-gradient(135deg, var(--cp-primary), var(--cp-accent));
        border-radius: 4px;
        margin: 0 auto 20px;
    }

    /* ═══════════════════════════════════════════
           TARJETAS DE INFORMACIÓN
        ═══════════════════════════════════════════ */
    .info-card {
        background: var(--cp-white);
        border: 1px solid var(--cp-border);
        border-radius: 16px;
        box-shadow: var(--cp-shadow);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        padding: 28px 24px;
        height: 100%;
    }

        .info-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--cp-shadow-lg);
        }

    .info-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
        margin-bottom: 16px;
    }

    .info-icon-primary {
        background: rgba(10,92,140,0.10);
        color: var(--cp-primary);
    }

    .info-icon-accent {
        background: var(--cp-accent-light);
        color: var(--cp-accent);
    }

    .info-icon-yellow {
        background: #fff8e1;
        color: #d4a017;
    }

    .info-icon-indigo {
        background: #ede9fe;
        color: #6d28d9;
    }

    .info-card-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--cp-text-muted);
        margin-bottom: 6px;
    }

    .info-card p {
        font-size: 0.92rem;
        color: var(--cp-text);
        margin: 0;
        line-height: 1.6;
    }

    .info-card a {
        color: var(--cp-primary);
        text-decoration: none;
        font-weight: 600;
    }

        .info-card a:hover {
            color: var(--cp-accent);
            text-decoration: underline;
        }

    /* ═══════════════════════════════════════════
           MAPA
        ═══════════════════════════════════════════ */
    .map-wrap {
        background: var(--cp-white);
        border-radius: 16px;
        box-shadow: var(--cp-shadow);
        border: 1px solid var(--cp-border);
        overflow: hidden;
    }

        .map-wrap iframe {
            display: block;
            width: 100%;
            height: 360px;
            border: 0;
        }

    /* ═══════════════════════════════════════════
           BOTONES
        ═══════════════════════════════════════════ */
    .btn-cp-primary {
        background: linear-gradient(120deg, var(--cp-primary), var(--cp-primary-light));
        border: none;
        color: white;
        padding: 12px 28px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 0.92rem;
        transition: all 0.25s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        box-shadow: 0 4px 14px rgba(10,92,140,0.30);
    }

        .btn-cp-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 22px rgba(10,92,140,0.38);
            color: white;
        }

    .btn-cp-outline {
        border: 2px solid var(--cp-primary);
        color: var(--cp-primary);
        padding: 11px 26px;
        border-radius: 30px;
        font-weight: 600;
        font-size: 0.92rem;
        transition: all 0.25s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        background: transparent;
    }

        .btn-cp-outline:hover {
            background: var(--cp-primary);
            color: white;
        }

    /* ═══════════════════════════════════════════
           RESPONSIVE
        ═══════════════════════════════════════════ */
    @@media (max-width: 768px) {
        .contact-hero h1 {
            font-size: 1.9rem;
        }
    }
</style>

<!-- ════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════ -->
<div class="contact-hero">
    <div class="contact-hero-blob"></div>
    <div class="contact-hero-inner">
        <span class="contact-hero-badge">🏥 Portal de Transparencia Clínica</span>
        <h1>Clínica <span>Buen Amanecer</span></h1>
        <p>Estamos aquí para ayudarte. Contáctanos cuando lo necesites.</p>
    </div>
</div>

<!-- ════════════════════════════════════════════════
     SECCIÓN PRINCIPAL
════════════════════════════════════════════════ -->
<section class="contact-section">
    <div class="contact-container">

        <!-- Cabecera -->
        <div class="text-center mb-4">
            <span class="contact-section-badge">Estamos para ti</span>
            <h2 class="contact-section-title">Información de Contacto</h2>
            <p class="contact-section-sub">Encuentra todas las vías para comunicarte con nosotros</p>
            <div class="contact-divider"></div>
        </div>

        <!-- Tarjetas de información -->
        <div class="row g-4 mb-5">

            <!-- Dirección -->
            <div class="col-sm-6 col-lg-3">
                <div class="info-card">
                    <div class="info-icon info-icon-primary">
                        <i class="bi bi-geo-alt-fill"></i>
                    </div>
                    <p class="info-card-label">Dirección</p>
                    <p>Av. San Pedro De La Paz 1024,<br />Puerto Montt, Chile</p>
                </div>
            </div>

            <!-- Teléfono -->
            <div class="col-sm-6 col-lg-3">
                <div class="info-card">
                    <div class="info-icon info-icon-accent">
                        <i class="bi bi-telephone-fill"></i>
                    </div>
                    <p class="info-card-label">Teléfono</p>
                    <p>
                        <a href="tel:+56998941073">+56 9 9894 1073</a>
                    </p>
                </div>
            </div>

            <!-- Correo -->
            <div class="col-sm-6 col-lg-3">
                <div class="info-card">
                    <div class="info-icon info-icon-yellow">
                        <i class="bi bi-envelope-fill"></i>
                    </div>
                    <p class="info-card-label">Correo Electrónico</p>
                    <p>
                        <a href="mailto:ClinicaBuenAmanecer@gmail.cl" style="word-break:break-all;">
                            ClinicaBuenAmanecer@gmail.cl
                        </a>
                    </p>
                </div>
            </div>

            <!-- Horario -->
            <div class="col-sm-6 col-lg-3">
                <div class="info-card">
                    <div class="info-icon info-icon-indigo">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                    <p class="info-card-label">Horario de Atención</p>
                    <p>Lunes a Viernes<br /><strong>08:00 – 21:00 hrs.</strong></p>
                </div>
            </div>

        </div>

        <!-- Mapa -->
        <div class="row g-4 justify-content-center">
            <div class="col-lg-8 col-xl-6">
                <div class="map-wrap mb-3">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3020.5!2d-73.0!3d-41.47!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDHCsDI4JzEyLjAiUyA3M8KwMDAnMDAuMCJX!5e0!3m2!1ses!2scl!4v1600000000000"
                            allowfullscreen=""
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
                <a href="https://maps.google.com/?q=Av.+San+Pedro+De+La+Paz+1024,+Puerto+Montt,+Chile"
                       target="_blank"
                       class="btn-cp-outline w-100 justify-content-center">
                    <i class="bi bi-map"></i> Ver en Google Maps
                </a>
            </div>
        </div>

    </div>
</section>
