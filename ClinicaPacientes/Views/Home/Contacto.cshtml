@{
    ViewData["Title"] = "Contacto";
}

<!-- Bootstrap Icons CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    .contact-hero {
        background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);
        color: white;
        padding: 60px 0 40px;
        margin-bottom: 40px;
    }

    .info-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s ease;
    }

        .info-card:hover {
            transform: translateY(-4px);
        }

    .info-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
    }

    .form-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    }

    .form-control:focus, .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
    }

    .btn-contact {
        background: linear-gradient(135deg, #0d6efd, #0dcaf0);
        border: none;
        color: white;
        padding: 12px 32px;
        border-radius: 50px;
        font-weight: 600;
        transition: opacity 0.2s ease;
    }

        .btn-contact:hover {
            opacity: 0.88;
            color: white;
        }

    .map-wrapper {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    }

    .divider-blue {
        width: 60px;
        height: 4px;
        background: linear-gradient(135deg, #0d6efd, #0dcaf0);
        border-radius: 4px;
        margin: 0 auto 20px;
    }
</style>

<!-- Hero -->
<div class="contact-hero text-center">
    <div class="container">
        <i class="bi bi-hospital fs-1 mb-3 d-block"></i>
        <h1 class="fw-bold mb-2">Clínica Buen Amanecer</h1>
        <p class="lead opacity-75 mb-0">Estamos aquí para ayudarte. Contáctanos cuando lo necesites.</p>
    </div>
</div>

<div class="container pb-5">

    <!-- Tarjetas de información -->
    <div class="text-center mb-4">
        <h2 class="fw-bold">Información de Contacto</h2>
        <div class="divider-blue"></div>
    </div>

    <div class="row g-4 mb-5">

        <!-- Dirección -->
        <div class="col-sm-6 col-lg-3">
            <div class="card info-card h-100 p-4">
                <div class="info-icon bg-primary bg-opacity-10 text-primary mb-3">
                    <i class="bi bi-geo-alt-fill"></i>
                </div>
                <h6 class="fw-bold text-secondary text-uppercase small mb-1">Dirección</h6>
                <p class="mb-0">Av. San Pedro De La Paz 1024,<br />Puerto Montt, Chile</p>
            </div>
        </div>

        <!-- Teléfono -->
        <div class="col-sm-6 col-lg-3">
            <div class="card info-card h-100 p-4">
                <div class="info-icon bg-success bg-opacity-10 text-success mb-3">
                    <i class="bi bi-telephone-fill"></i>
                </div>
                <h6 class="fw-bold text-secondary text-uppercase small mb-1">Teléfono</h6>
                <p class="mb-0">
                    <a href="tel:+56998941073" class="text-decoration-none text-dark fw-semibold">
                        +56 9 9894 1073
                    </a>
                </p>
            </div>
        </div>

        <!-- Correo -->
        <div class="col-sm-6 col-lg-3">
            <div class="card info-card h-100 p-4">
                <div class="info-icon bg-warning bg-opacity-10 text-warning mb-3">
                    <i class="bi bi-envelope-fill"></i>
                </div>
                <h6 class="fw-bold text-secondary text-uppercase small mb-1">Correo Electrónico</h6>
                <p class="mb-0">
                    <a href="mailto:ClinicaBuenAmanecer@gmail.cl" class="text-decoration-none text-dark fw-semibold" style="word-break:break-all;">
                        ClinicaBuenAmanecer@gmail.cl
                    </a>
                </p>
            </div>
        </div>

        <!-- Horario -->
        <div class="col-sm-6 col-lg-3">
            <div class="card info-card h-100 p-4">
                <div class="info-icon bg-info bg-opacity-10 text-info mb-3">
                    <i class="bi bi-clock-fill"></i>
                </div>
                <h6 class="fw-bold text-secondary text-uppercase small mb-1">Horario de Atención</h6>
                <p class="mb-0">Lunes a Viernes<br /><span class="fw-semibold">08:00 – 21:00 hrs.</span></p>
            </div>
        </div>

    </div>

    <!-- Formulario + Mapa -->
    <div class="row g-4 justify-content-center">
        
        <!-- Mapa -->
        <div class="col-lg-8 col-xl-6">
            <div class="map-wrapper mb-3">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3020.5!2d-73.0!3d-41.47!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDHCsDI4JzEyLjAiUyA3M8KwMDAnMDAuMCJX!5e0!3m2!1ses!2scl!4v1600000000000"
                        width="100%"
                        height="360"
                        style="border:0; display:block;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>
            <!-- Botón ir a Google Maps -->
            <a href="https://maps.google.com/?q=Av.+San+Pedro+De+La+Paz+1024,+Puerto+Montt,+Chile"
                   target="_blank"
                   class="btn btn-outline-primary w-100 rounded-pill fw-semibold">
                <i class="bi bi-map me-2"></i>Ver en Google Maps
            </a>
        </div>

    </div>
</div>
