@model List<ClinicaPacientes.Models.Paciente>

@{
    ViewData["Title"] = "Administración de Pacientes";
}

<h2 class="mt-3">Administración de Pacientes</h2>
<hr />

@* ══════════════ FORMULARIO ══════════════ *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        ⚠️ @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form id="formPaciente" asp-action="Registrar" method="post">
    @Html.AntiForgeryToken()

    <div class="row g-3">

        <div class="col-md-2">
            <label class="form-label fw-bold">ID Paciente</label>
            <input type="number" id="idPaciente" name="idPaciente"
                   class="form-control" readonly
                   style="background-color:#e9ecef; cursor:not-allowed
;" />
            <small class="text-muted">Generado automáticamente</small>
        </div>

        <div class="col-md-4">
            <label class="form-label fw-bold">Nombre</label>
            <input type="text" id="nombrePaciente" name="nombrePaciente"
                   class="form-control" required />
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">RUT</label>
            <input type="text" id="rutPaciente" name="rutPaciente"
                   class="form-control" placeholder="12345678-9"
                   pattern="\d{7,8}-[\dkK]"
                   title="Formato válido: 12345678-9 o 1234567-K"
                   required />
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">Fecha de Ingreso</label>
            <input type="datetime-local" id="fechaIngreso" name="fechaIngreso"
                   class="form-control" required />
        </div>

        <div class="col-md-2">
            <label class="form-label fw-bold">Edad</label>
            <input type="number" id="edadPaciente" name="edadPaciente"
                   class="form-control" min="1" max="120" required />
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">Teléfono</label>
            <input type="text" id="telefonoPaciente" name="telefonoPaciente"
                   class="form-control" required />
        </div>

        <div class="col-md-4">
            <label class="form-label fw-bold">Email</label>
            <input type="email" id="emailPaciente" name="emailPaciente"
                   class="form-control" required />
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">Dirección</label>
            <input type="text" id="direccionPaciente" name="direccionPaciente"
                   class="form-control" required />
        </div>

        <div class="col-md-12">
            <label class="form-label fw-bold">Motivo de Consulta</label>
            <input type="text" id="motivoConsulta" name="motivoConsulta"
                   class="form-control" required />
        </div>

    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-success">
            ✔ Registrar
        </button>
        <button type="button" class="btn btn-warning" id="btnModificar" disabled>
            ✏️ Modificar
        </button>
        <button type="button" class="btn btn-danger" id="btnEliminar" onclick="eliminarPaciente()" disabled>
            🗑 Eliminar
        </button>
        <button type="button" class="btn btn-secondary" onclick="cancelarFormulario()">
            ✖ Cancelar
        </button>
    </div>

</form>

<hr />

@* ══════════════ TABLA DE PACIENTES ══════════════ *@
<h4>Pacientes Registrados</h4>
<table class="table table-bordered table-hover mt-2" id="tablaPacientes">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>RUT</th>
            <th>Fecha Ingreso</th>
            <th>Edad</th>
            <th>Teléfono</th>
            <th>Email</th>
            <th>Dirección</th>
            <th>Motivo Consulta</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr class="fila-paciente"
                data-id="@p.idPaciente"
                data-nombre="@p.nombrePaciente"
                data-rut="@p.rutPaciente"
                data-fecha="@p.fechaIngreso.ToString("yyyy-MM-ddTHH:mm")"
                data-edad="@p.edadPaciente"
                data-telefono="@p.telefonoPaciente"
                data-email="@p.emailPaciente"
                data-direccion="@p.direccionPaciente"
                data-motivo="@p.motivoConsulta"
                style="cursor:pointer;">
                <td>@p.idPaciente</td>
                <td>@p.nombrePaciente</td>
                <td>@p.rutPaciente</td>
                <td>@p.fechaIngreso.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@p.edadPaciente</td>
                <td>@p.telefonoPaciente</td>
                <td>@p.emailPaciente</td>
                <td>@p.direccionPaciente</td>
                <td>@p.motivoConsulta</td>
            </tr>
        }
    </tbody>
</table>

@* ══════════════ JAVASCRIPT ══════════════ *@
<script>

    function validarRut(rut) {
        return /^\d{7,8}-[\dkK]$/.test(rut);
    }

    function validarFormulario() {
        const campos = [
            'nombrePaciente', 'rutPaciente', 'fechaIngreso',
            'edadPaciente',   'telefonoPaciente', 'emailPaciente',
            'direccionPaciente', 'motivoConsulta'
        ];


        for (let id of campos) {
            const campo = document.getElementById(id);
            if (!campo.value.trim()) {
                alert(`El campo "${campo.previousElementSibling.textContent.trim()}" es obligatorio.`);
                campo.focus();
                return false;
            }
        }
            if (!validarRut(document.getElementById('rutPaciente').value.trim())) {
                alert('El RUT debe tener el formato correcto.\nEjemplo: 12345678-9 o 1234567-K');
                document.getElementById('rutPaciente').focus();
                return false;
             }

    // ← NUEVO: verificar RUT duplicado en la tabla
    const rutIngresado = document.getElementById('rutPaciente').value.trim();
    const idActual     = document.getElementById('idPaciente').value.trim();
    if (rutYaRegistrado(rutIngresado, idActual)) {
        alert('⚠️ El RUT ya está registrado en el sistema.\nPor favor ingrese otro.');
        document.getElementById('rutPaciente').focus();
        return false;
    }

            // Verifica si el RUT ya existe en la tabla (excluyendo el paciente actual al modificar)
    function rutYaRegistrado(rut, idActual) {
        const filas = document.querySelectorAll('.fila-paciente');
        for (let fila of filas) {
            if (fila.dataset.rut === rut && fila.dataset.id !== idActual) {
                return true;
            }
        }
        return false;
    }

        const edad = parseInt(document.getElementById('edadPaciente').value);
        if (isNaN(edad) || edad < 1 || edad > 120) {
            alert('La edad debe ser un número positivo entre 1 y 120.');
            document.getElementById('edadPaciente').focus();
            return false;
        }

        return true;
    }

    document.querySelectorAll('.fila-paciente').forEach(function (fila) {
        fila.addEventListener('click', function () {
            document.querySelectorAll('.fila-paciente')
                    .forEach(f => f.classList.remove('table-primary'));
            this.classList.add('table-primary');

            document.getElementById('idPaciente').value        = this.dataset.id;
            document.getElementById('nombrePaciente').value    = this.dataset.nombre;
            document.getElementById('rutPaciente').value       = this.dataset.rut;
            document.getElementById('fechaIngreso').value      = this.dataset.fecha;
            document.getElementById('edadPaciente').value      = this.dataset.edad;
            document.getElementById('telefonoPaciente').value  = this.dataset.telefono;
            document.getElementById('emailPaciente').value     = this.dataset.email;
            document.getElementById('direccionPaciente').value = this.dataset.direccion;
            document.getElementById('motivoConsulta').value    = this.dataset.motivo;
        });
    });

    document.getElementById('formPaciente').addEventListener('submit', function (e) {
        if (!validarFormulario()) {
            e.preventDefault();
        }
    });

    document.getElementById('btnModificar').addEventListener('click', function () {
        const id = document.getElementById('idPaciente').value;
        if (!id) {
            alert('Primero selecciona un paciente de la tabla.');
            return;
        }
        if (!validarFormulario()) return;

        document.getElementById('formPaciente').action = '/Administracion/Modificar';
        document.getElementById('formPaciente').submit();
    });

    function eliminarPaciente() {
        const idPaciente = document.getElementById('idPaciente').value;

        if (!idPaciente) {
            alert('Debe seleccionar un paciente de la tabla.');
            return;
        }

        if (!confirm('¿Desea eliminar este paciente?')) return;

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const form        = document.createElement('form');
        form.method       = 'post';
        form.action       = '/Administracion/Eliminar';

        const inputId     = document.createElement('input');
        inputId.type      = 'hidden';
        inputId.name      = 'idPaciente';
        inputId.value     = idPaciente;

        const inputToken  = document.createElement('input');
        inputToken.type   = 'hidden';
        inputToken.name   = '__RequestVerificationToken';
        inputToken.value  = token;

        form.appendChild(inputId);
        form.appendChild(inputToken);
        document.body.appendChild(form);
        form.submit();
    }

    function cancelarFormulario() {
        ['idPaciente', 'nombrePaciente', 'rutPaciente', 'fechaIngreso',
         'edadPaciente', 'telefonoPaciente', 'emailPaciente',
         'direccionPaciente', 'motivoConsulta'].forEach(id => {
            document.getElementById(id).value = '';
        });

        // Restaurar action original del formulario
        document.getElementById('formPaciente').action = '/Administracion/Registrar';
        document.querySelectorAll('.fila-paciente')
                .forEach(f => f.classList.remove('table-primary'));

        document.querySelector('[type="submit"]').disabled = false;
        document.getElementById('btnModificar').disabled   = true;
        document.getElementById('btnEliminar').disabled    = true;
    }

</script>